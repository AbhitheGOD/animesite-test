{
  "version": 2,
  "builds": [
    { "src": "api/anime.js",            "use": "@vercel/node" },
    { "src": "api/similar.js",          "use": "@vercel/node" },
    { "src": "api/recommend.js",        "use": "@vercel/node" },
    { "src": "api/trending.js",         "use": "@vercel/node" },
    { "src": "api/waitlist.js",         "use": "@vercel/node" },
    { "src": "api/search.js",           "use": "@vercel/node" },
    { "src": "api/search-advanced.js", "use": "@vercel/node" },
    { "src": "api/supabase-config.js",  "use": "@vercel/node" },
    { "src": "api/hyperbeam.js",        "use": "@vercel/node" },
    { "src": "index.html",              "use": "@vercel/static" },
    { "src": "anime.html",              "use": "@vercel/static" },
    { "src": "rooms.html",              "use": "@vercel/static" },
    { "src": "chat.html",               "use": "@vercel/static" },
    { "src": "history.html",            "use": "@vercel/static" },
    { "src": "watchlist.html",          "use": "@vercel/static" },
    { "src": "settings.html",           "use": "@vercel/static" },
    { "src": "profile.html",            "use": "@vercel/static" },
    { "src": "assets/**",               "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/anime",            "dest": "/api/anime.js" },
    { "src": "/api/similar",          "dest": "/api/similar.js" },
    { "src": "/api/recommend",        "dest": "/api/recommend.js" },
    { "src": "/api/trending",         "dest": "/api/trending.js" },
    { "src": "/api/waitlist",         "dest": "/api/waitlist.js" },
    { "src": "/api/search",           "dest": "/api/search.js" },
    { "src": "/api/search-advanced", "dest": "/api/search-advanced.js" },
    { "src": "/api/supabase-config",  "dest": "/api/supabase-config.js" },
    { "src": "/api/hyperbeam",        "dest": "/api/hyperbeam.js" },
    { "src": "/anime.html",           "dest": "/anime.html" },
    { "src": "/rooms.html",           "dest": "/rooms.html" },
    { "src": "/chat.html",            "dest": "/chat.html" },
    { "src": "/history.html",         "dest": "/history.html" },
    { "src": "/watchlist.html",       "dest": "/watchlist.html" },
    { "src": "/settings.html",        "dest": "/settings.html" },
    { "src": "/profile.html",         "dest": "/profile.html" },
    { "src": "/assets/(.*)",          "dest": "/assets/$1" },
    { "src": "/(.*)",                 "dest": "/index.html" }
  ]
}

